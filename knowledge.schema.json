{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/rhel-knowledge-v3.schema.json",
  "title": "RHEL Arabic Knowledge Engine V3",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "language",
    "supported_versions",
    "entity_types",
    "categories",
    "entities"
  ],
  "properties": {
    "schema_version": {
      "const": "3.0.0"
    },
    "project": {
      "type": "string"
    },
    "language": {
      "const": "ar"
    },
    "baseline": {
      "type": "string"
    },
    "supported_versions": {
      "type": "array",
      "items": {
        "enum": [
          "8",
          "9",
          "10"
        ]
      }
    },
    "entity_types": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entity"
      }
    }
  },
  "$defs": {
    "common": {
      "type": "object",
      "required": [
        "id",
        "entity_type",
        "title_ar",
        "summary_ar",
        "category",
        "keywords_ar",
        "difficulty",
        "supported_versions",
        "related_entities",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "entity_type": {
          "enum": [
            "task",
            "command",
            "concept",
            "troubleshooting",
            "learning_path"
          ]
        },
        "title_ar": {
          "type": "string",
          "minLength": 2
        },
        "summary_ar": {
          "type": "string",
          "minLength": 3
        },
        "category": {
          "type": "string"
        },
        "keywords_ar": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "difficulty": {
          "enum": [
            "beginner",
            "intermediate",
            "advanced"
          ]
        },
        "supported_versions": {
          "type": "array",
          "items": {
            "enum": [
              "8",
              "9",
              "10"
            ]
          }
        },
        "related_entities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags_ar": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "enum": [
            "draft",
            "reviewed",
            "verified"
          ]
        }
      }
    },
    "entity": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "if": {
            "properties": {
              "entity_type": {
                "const": "command"
              }
            }
          },
          "then": {
            "required": [
              "command_name",
              "purpose_ar",
              "syntax",
              "options",
              "examples",
              "risk"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "entity_type": {
                "const": "concept"
              }
            }
          },
          "then": {
            "required": [
              "definition_ar",
              "why_it_matters_ar",
              "key_points_ar"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "entity_type": {
                "const": "learning_path"
              }
            }
          },
          "then": {
            "required": [
              "description_ar",
              "estimated_hours",
              "modules",
              "outcomes_ar"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "entity_type": {
                "enum": [
                  "task",
                  "troubleshooting"
                ]
              }
            }
          },
          "then": {
            "required": [
              "goal_ar",
              "estimated_minutes",
              "risk",
              "steps",
              "verification",
              "common_errors"
            ]
          }
        }
      ]
    }
  }
}
